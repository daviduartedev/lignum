# Normalize line endings: LF in repo, autocrlf handles checkout on Windows.
* text=auto eol=lf

# Windows scripts keep CRLF.
*.{cmd,bat} text eol=crlf

# Binary assets — no EOL conversion.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
