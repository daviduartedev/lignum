{
  "name": "lignum-gestao",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:dump": "npx tsx scripts/db/dump.ts",
    "db:reset": "npx tsx scripts/db/reset.ts",
    "db:seed": "npx prisma db seed",
    "test:smoke": "npx tsx scripts/test/smoke.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:security": "vitest run",
    "test:security:watch": "vitest",
    "audit:ci": "npm audit --audit-level=high",
    "secrets:scan": "gitleaks detect --redact --source . --log-opts=\"--all\""
  },
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-pdf/renderer": "^4.5.1",
    "@tailwindcss/postcss": "^4.1.12",
    "@tanstack/react-query": "^5.96.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/blob": "^0.27.1",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.487.0",
    "next": "^15.5.18",
    "next-auth": "^5.0.0-beta.25",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-toastify": "^11.0.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.3.8",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "prisma": "^6.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "undici": ">=6.23.1"
  }
}
