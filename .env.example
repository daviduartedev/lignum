# Neon / PostgreSQL — obrigatório para login e APIs
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# NextAuth v5 — obrigatório (dev: openssl rand -base64 32)
AUTH_SECRET="gerar-com-openssl-rand-base64-32"

# Upstash Redis (rate-limit persistente em produção/preview; opcional em dev, fallback in-memory)
# UPSTASH_REDIS_REST_URL="https://....upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."
# Opcional em dev; em produção (Vercel) define o URL público da app
# AUTH_URL="https://seu-dominio.vercel.app"

# CORS: origens cross-origin permitidas por ambiente, separadas por virgula. Sem wildcard.
# ALLOWED_ORIGINS="https://preview.example.com,https://app.example.com"

# Vercel Blob (uploads — fotos e anexos)
# 1. Vercel Dashboard → Project → Storage → Blob → Create → access **Public**
# 2. Connect to Project → copiar BLOB_READ_WRITE_TOKEN gerado automaticamente
# 3. Só activar upload após checklist de segurança revisto:
BLOB_READ_WRITE_TOKEN=""
ENABLE_SERVER_UPLOADS="false"
UPLOAD_SECURITY_CHECKLIST_CONFIRMED="false"
# Limites (código): corpo máx. 1 MiB/pedido; MIME image/jpeg|png|webp|gif + application/pdf;
# máx. 20 ficheiros/pedido; armazenamento exclusivamente Blob (prefixo lignum/), nunca filesystem local.

# Consulta cadastral CNPJ (cycle 0706)
# DOCUMENT_LOOKUP_PROVIDER="mock"
# DOCUMENT_LOOKUP_CACHE_TTL_SECONDS="86400"
# DOCUMENT_LOOKUP_UNIT_COST_BRL="0"
# DOCUMENT_LOOKUP_BRASILAPI_BASE="https://brasilapi.com.br/api/cnpj/v1"
# DOCUMENT_LOOKUP_HTTP_BASE=""
# DOCUMENT_LOOKUP_HTTP_TOKEN=""
# DOCUMENT_LOOKUP_HTTP_TIMEOUT_MS="8000"

# UI, cadastro público (Register). Predefinição: apenas admin cria utilizadores em /configuracoes/usuarios/novo
NEXT_PUBLIC_ENABLE_SELF_SIGNUP="false"

# Storefront multitenant (legado — removido no cycle 0623 Stage 2):
# LIGNUM_BASE_DOMAIN=lignumgestao.com.br
# NEXT_PUBLIC_BASE_DOMAIN=lignumgestao.com.br
LIGNUM_BASE_DOMAIN="localhost:3000"
NEXT_PUBLIC_BASE_DOMAIN="localhost:3000"

# prisma db seed, utilizadores de dev (opcional)
# SEED_ADMIN_EMAIL="admin@lignum.local"
# SEED_ADMIN_PASSWORD="Teste@123456"
# SEED_ADMIN_NAME="Admin Lignum"
# SEED_OWNER_EMAIL="admin@lignum.local"
# SEED_CLEAR="true"

# Playwright (alinhado ao seed)
# E2E_PASSWORD="Teste@123456"
# E2E_ADMIN_EMAIL="admin@lignum.local"
