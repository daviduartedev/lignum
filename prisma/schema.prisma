// Lignum Gestão — schema Prisma (single-tenant)
// Fonte de campos: frontend/src/types/index.ts + patches em strapi/patches/
// Media Strapi → URLs armazenadas (Vercel Blob) em campos String / String[] / Json

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  vendedor
  financeiro
  producao
  read_only
}

enum AuditAction {
  login_success
  login_failure
  user_created
  user_updated
  user_deactivated
  user_reactivated
  user_role_changed
  user_password_reset
  erp_setting_updated
}

enum VehicleStatus {
  disponivel
  repasse
  reservado
  vendido
  removido
  /** Avaliação de compra concluída como não comprado, fora do estoque ativo */
  standby_nao_compra
}

enum FuelType {
  flex
  gasolina
  diesel
  eletrico
  hibrido
}

enum TransmissionType {
  manual
  automatico
  cvt
}

enum PaymentMethod {
  financiamento
  a_vista
  cartao
  troca
  pix
  promissoria
}

enum PurchaseEvaluationOutcome {
  pendente
  nao_comprado
  comprado
}

enum PurchaseEvaluationReason {
  preco
  estado
  documentacao
  desistencia
  outro
}

enum ContractType {
  compra_venda
  financiamento
  consorcio
  locacao
}

enum ContractStatus {
  rascunho
  pendente_assinatura
  assinado
  cancelado
}

enum ServiceOrderType {
  manutencao
  revisao
  funilaria
  eletrica
  mecanica
  estetica
  outros
}

enum ServiceOrderStatus {
  aguardando
  andamento
  concluida
  cancelada
}

enum WarrantyType {
  motor_cambio
  completa
  motor
  acessorios
  outros
}

enum WarrantyStatus {
  ativa
  vencendo
  expirada
  cancelada
}

enum PromissoryNoteStatus {
  aberta
  paga
  vencida
  cancelada
}

enum PayableStatus {
  aberta
  paga
  vencida
  cancelada
}

enum PersonType {
  pf @map("PF")
  pj @map("PJ")
}

enum PayableOrigin {
  manual
  compra_veiculo
  outro
}

enum FinanceEventType {
  promissory_note_due
  payable_due
}

/// Situação legal na fonte consultada (não confundir com VehicleStatus de estoque).
enum VehicleLegalSituation {
  regular
  irregular
  com_restricao
}

enum VehicleCategoryKind {
  carro
  moto
  onibus
  jet_ski
  outros
}

enum VehicleCautelar {
  nao
  leilao
  sinistro
  leilao_sinistro
  outras_restricoes
}

/// Utilizador da aplicação (substitui users-permissions do Strapi).
model User {
  id                           Int       @id @default(autoincrement())
  email                        String    @unique
  passwordHash                 String    @map("password_hash")
  name                         String?
  role                         Role      @default(vendedor)
  isActive                     Boolean   @default(true) @map("is_active")
  lgpdConsentVersion           String?   @map("lgpd_consent_version")
  lgpdConsentAt                DateTime? @map("lgpd_consent_at")
  showDashboardAttentionStripe Boolean   @default(true) @map("show_dashboard_attention_stripe")
  financeEventNotifyDaysBeforeOverride Int? @map("finance_event_notify_days_before_override")
  sessionRevokedAt             DateTime? @map("session_revoked_at")
  createdAt                    DateTime  @default(now()) @map("created_at")
  updatedAt                    DateTime  @updatedAt @map("updated_at")

  notifications              UserNotification[]
  senatranLookupAudits       SenatranLookupAudit[]
  documentLookupAudits       DocumentLookupAudit[]
  auditLogs                  AuditLog[]
  stockAttentionPreferences  UserStockAttentionPreference[]
  financeNotificationDispatches FinanceNotificationDispatch[]
  sales                      Sale[] @relation("SaleSeller")

  @@map("users")
}

model AuditLog {
  id           Int         @id @default(autoincrement())
  userId       Int?        @map("user_id")
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       AuditAction
  resourceType String      @map("resource_type")
  resourceId   String?     @map("resource_id")
  metadata     Json        @default("{}")
  createdAt    DateTime    @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([resourceType, createdAt])
  @@map("audit_logs")
}

model Vehicle {
  id                         Int                @id @default(autoincrement())
  documentId                 String?            @unique @map("document_id")
  plate                      String
  brand                      String
  model                      String
  version                    String?
  yearManufacture            Int                @map("year_manufacture")
  yearModel                  Int                @map("year_model")
  mileage                    Int
  color                      String?
  fuel                       FuelType?
  transmission               TransmissionType?
  fipePrice                  Decimal?           @map("fipe_price") @db.Decimal(14, 2)
  purchasePrice              Decimal            @map("purchase_price") @db.Decimal(14, 2)
  estimatedMaintenanceCost   Decimal?           @map("estimated_maintenance_cost") @db.Decimal(14, 2)
  sellingPrice               Decimal?           @map("selling_price") @db.Decimal(14, 2)
  minimumSellingPrice        Decimal?           @map("minimum_selling_price") @db.Decimal(14, 2)
  status                     VehicleStatus
  observations               String?

  /** Campos operacionais de compra (opcionais). */
  doorsCount                 Int?               @map("doors_count")
  lastLicensingDate          DateTime?          @map("last_licensing_date") @db.Date
  purchaseEntryAt            DateTime?          @map("purchase_entry_at")
  purchaseEntryMileage       Int?               @map("purchase_entry_mileage")
  purchaseSupplierId         Int?               @map("purchase_supplier_id")
  purchaseSupplier           Supplier?          @relation("VehiclePurchaseSupplier", fields: [purchaseSupplierId], references: [id], onDelete: SetNull)
  purchasePaymentJson        Json?              @map("purchase_payment_json")

  mainPhotoUrl               String?            @map("main_photo_url")
  galleryUrls                String[]           @default([]) @map("gallery_urls")
  attachmentUrls             String[]           @default([]) @map("attachment_urls")
  buyerId                    Int?               @map("buyer_id")
  buyer                      Client?            @relation("VehicleBuyer", fields: [buyerId], references: [id])
  renavam                    String             @default("")
  chassis                    String             @default("")
  legalSituation             VehicleLegalSituation @default(regular) @map("legal_situation")
  categoryKind               VehicleCategoryKind @default(carro) @map("category_kind")
  cautelar                   VehicleCautelar    @default(nao)
  speciesCategory            String?            @map("species_category")
  registrationCity           String?            @map("registration_city")
  registrationUf             String?            @map("registration_uf")
  listingTitle               String?            @map("listing_title")
  officialExtraFields        Json?              @map("official_extra_fields")
  senatranFieldProvenance    Json?              @map("senatran_field_provenance")
  createdAt                  DateTime           @default(now()) @map("created_at")
  updatedAt                  DateTime           @updatedAt @map("updated_at")

  sale           Sale?
  contracts      Contract[]
  evaluations    Evaluation[]
  purchaseEvaluations PurchaseEvaluation[]
  serviceOrders  ServiceOrder[]
  warranties     Warranty[]
  promissoryNotes             PromissoryNote[]
  payables                   Payable[]
  stockAttentionPreferences   UserStockAttentionPreference[]
  storefrontLeads            StorefrontLead[]

  @@index([status])
  @@index([plate])
  @@index([buyerId])
  @@index([purchaseSupplierId])
  @@map("vehicles")
}

model UserStockAttentionPreference {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId    Int       @map("vehicle_id")
  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  snoozedUntil DateTime? @map("snoozed_until")
  dismissed    Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([userId, vehicleId])
  @@index([userId])
  @@map("user_stock_attention_preferences")
}

model Client {
  id                 Int         @id @default(autoincrement())
  documentId         String?     @unique @map("document_id")
  fullName           String      @map("full_name")
  document           String
  email              String
  phone              String?
  address            String?
  personType         PersonType? @map("person_type")
  rg                 String?
  maritalStatus      String?     @map("marital_status")
  profession         String?
  zipCode            String?     @map("zip_code")
  nationality        String?
  neighborhood       String?
  street             String?
  city               String?
  streetNumber       String?     @map("street_number")
  addressComplement  String?     @map("address_complement")
  birthDate          DateTime?   @map("birth_date") @db.Date
  registrationStatus String?     @map("registration_status")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  boughtVehicles Vehicle[]      @relation("VehicleBuyer")
  sales          Sale[]
  contracts      Contract[]
  warranties     Warranty[]
  promissoryNotes PromissoryNote[]
  documents      ClientDocument[]
  purchaseEvaluations PurchaseEvaluation[]

  @@index([document])
  @@index([email])
  @@map("clients")
}

model ClientDocument {
  id              Int       @id @default(autoincrement())
  documentId      String?   @unique @map("document_id")
  title           String
  notes           String?
  externalUrl     String?   @map("external_url")
  documentFileUrl String?   @map("document_file_url")
  clientId        Int       @map("client_id")
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([clientId])
  @@map("client_documents")
}

model Sale {
  id             Int            @id @default(autoincrement())
  documentId     String?        @unique @map("document_id")
  saleDate       DateTime       @map("sale_date") @db.Date
  finalPrice     Decimal        @map("final_price") @db.Decimal(14, 2)
  paymentMethod  PaymentMethod? @map("payment_method")
  financingBank  String?        @map("financing_bank")
  notes          String?
  vehicleId      Int            @unique @map("vehicle_id")
  vehicle        Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  clientId       Int            @map("client_id")
  client         Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  sellerUserId   Int?           @map("seller_user_id")
  sellerUser     User?          @relation("SaleSeller", fields: [sellerUserId], references: [id], onDelete: SetNull)
  sellerName     String?        @map("seller_name")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([sellerUserId])
  @@index([saleDate])
  @@map("sales")
}

model Contract {
  id                 Int            @id @default(autoincrement())
  documentId         String?        @unique @map("document_id")
  contractType       ContractType   @map("contract_type")
  contractValue      Decimal        @map("contract_value") @db.Decimal(14, 2)
  contractDate       DateTime       @map("contract_date") @db.Date
  status             ContractStatus
  specialClauses     String?        @map("special_clauses")
  witness1Name       String?        @map("witness_1_name")
  witness1Document   String?        @map("witness_1_document")
  witness2Name       String?        @map("witness_2_name")
  witness2Document   String?        @map("witness_2_document")
  vehicleId          Int            @map("vehicle_id")
  vehicle            Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  clientId           Int            @map("client_id")
  client             Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([clientId])
  @@index([status])
  @@map("contracts")
}

model Evaluation {
  id              Int       @id @default(autoincrement())
  documentId      String?   @unique @map("document_id")
  score           Float?
  observations    String?
  technicalNotes  String?   @map("technical_notes")
  checklistJson   Json?     @map("checklist_json")
  photoUrls       String[]  @default([]) @map("photo_urls")
  vehicleId       Int       @map("vehicle_id")
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@map("evaluations")
}

model PurchaseEvaluation {
  id             Int                       @id @default(autoincrement())
  documentId     String?                   @unique @map("document_id")
  vehicleId      Int                       @map("vehicle_id")
  vehicle        Vehicle                   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  clientId       Int?                      @map("client_id")
  client         Client?                   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  outcome        PurchaseEvaluationOutcome
  reasonCode     PurchaseEvaluationReason? @map("reason_code")
  reasonDetail   String?                   @map("reason_detail")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([clientId])
  @@map("purchase_evaluations")
}

model ServiceOrder {
  id            Int                 @id @default(autoincrement())
  documentId    String?             @unique @map("document_id")
  workshopName  String              @map("workshop_name")
  serviceType   ServiceOrderType    @map("service_type")
  serviceTypeOtherText String?      @map("service_type_other_text")
  status        ServiceOrderStatus
  entryDate     DateTime            @map("entry_date") @db.Date
  dueDate       DateTime?           @map("due_date") @db.Date
  responsible   String?
  description   String?
  partsJson     Json?               @map("parts_json")
  laborJson     Json?               @map("labor_json")
  totalAmount   Decimal             @map("total_amount") @db.Decimal(14, 2)
  photoUrls     String[]            @default([]) @map("photo_urls")
  vehicleId     Int                 @map("vehicle_id")
  vehicle       Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([status])
  @@map("service_orders")
}

model Warranty {
  id             Int             @id @default(autoincrement())
  documentId     String?         @unique @map("document_id")
  warrantyType   WarrantyType    @map("warranty_type")
  startDate      DateTime        @map("start_date") @db.Date
  endDate        DateTime        @map("end_date") @db.Date
  coverageValue  Decimal         @map("coverage_value") @db.Decimal(14, 2)
  status         WarrantyStatus
  notes          String?
  vehicleId      Int             @map("vehicle_id")
  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  clientId       Int             @map("client_id")
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([clientId])
  @@map("warranties")
}

model PromissoryNote {
  id                  Int                   @id @default(autoincrement())
  documentId        String?               @unique @map("document_id")
  installmentNumber   Int                   @map("installment_number")
  totalInstallments   Int                   @map("total_installments")
  dueDate             DateTime              @map("due_date") @db.Date
  amount              Decimal               @db.Decimal(14, 2)
  status              PromissoryNoteStatus
  paymentDate         DateTime?             @map("payment_date") @db.Date
  notes               String?
  clientId            Int                   @map("client_id")
  client              Client                @relation(fields: [clientId], references: [id], onDelete: Restrict)
  vehicleId           Int                   @map("vehicle_id")
  vehicle             Vehicle               @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([vehicleId])
  @@index([dueDate])
  @@map("promissory_notes")
}

model Supplier {
  id                  Int       @id @default(autoincrement())
  documentId          String?   @unique @map("document_id")
  companyName         String    @map("company_name")
  document            String?
  phone               String?
  email               String?
  notes               String?
  zipCode             String?   @map("zip_code")
  neighborhood        String?
  street              String?
  city                String?
  streetNumber        String?   @map("street_number")
  addressComplement   String?   @map("address_complement")
  registrationStatus  String?   @map("registration_status")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  purchasedVehicles Vehicle[] @relation("VehiclePurchaseSupplier")
  payables     Payable[]

  @@index([companyName])
  @@map("suppliers")
}

model Payable {
  id          Int          @id @default(autoincrement())
  documentId  String?      @unique @map("document_id")
  origin      PayableOrigin
  description String       @default("")
  dueDate     DateTime     @map("due_date") @db.Date
  amount      Decimal      @db.Decimal(14, 2)
  status      PayableStatus @default(aberta)
  paymentDate DateTime?    @map("payment_date") @db.Date
  notes       String?

  vehicleId   Int?         @map("vehicle_id")
  vehicle     Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  supplierId  Int?         @map("supplier_id")
  supplier    Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([dueDate])
  @@index([status])
  @@index([origin])
  @@index([vehicleId])
  @@index([supplierId])
  @@map("payables")
}

/// Notificações in-app (owner_user_id no Strapi → FK para User).
model UserNotification {
  id           Int       @id @default(autoincrement())
  documentId   String?   @unique @map("document_id")
  title        String
  body         String
  read         Boolean   @default(false)
  link         String?
  remindAt     DateTime? @map("remind_at")
  ownerUserId  Int       @map("owner_user_id")
  owner        User      @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([ownerUserId])
  @@index([read])
  @@index([remindAt])
  @@map("user_notifications")
}

/// Registo de dispatch para idempotência (avisos financeiros).
model FinanceNotificationDispatch {
  id           Int            @id @default(autoincrement())
  eventType    FinanceEventType @map("event_type")
  eventId      Int            @map("event_id")
  ownerUserId  Int            @map("owner_user_id")
  owner        User           @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  scheduledFor DateTime       @map("scheduled_for")
  sentAt       DateTime?      @map("sent_at")
  cancelledAt  DateTime?      @map("cancelled_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@unique([eventType, eventId, ownerUserId, scheduledFor])
  @@index([ownerUserId])
  @@index([scheduledFor])
  @@map("finance_notification_dispatches")
}

/// Configuração da fábrica — singleton (id = 1).
model ErpSetting {
  id                       Int      @id @default(1)
  companyName              String   @default("") @map("company_name")
  companyTaxId             String   @default("") @map("company_tax_id")
  companyStateReg          String   @default("") @map("company_state_reg")
  companyAddress           String   @default("") @map("company_address")
  companyCity              String   @default("") @map("company_city")
  companyState             String   @default("") @map("company_state")
  companyZip               String   @default("") @map("company_zip")
  companyPhone             String   @default("") @map("company_phone")
  companyEmail             String   @default("") @map("company_email")
  alertGiroEnabled         Boolean  @default(true) @map("alert_giro_enabled")
  alertGiroWarnDays        Int      @default(30) @map("alert_giro_warn_days")
  alertGiroCritDays        Int      @default(45) @map("alert_giro_crit_days")
  alertPromEnabled         Boolean  @default(true) @map("alert_prom_enabled")
  alertPromDaysBefore      Int      @default(7) @map("alert_prom_days_before")
  alertDocsEnabled         Boolean  @default(true) @map("alert_docs_enabled")
  alertEmailDigestEnabled  Boolean  @default(true) @map("alert_email_digest_enabled")
  financeEventNotifyDaysBefore Int  @default(1) @map("finance_event_notify_days_before")
  inboxPreEventPopupMinutes Int     @default(30) @map("inbox_pre_event_popup_minutes")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@map("erp_settings")
}

/// Auditoria de consultas SENATRAN (snapshot completo; acesso administrativo).
model SenatranLookupAudit {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plateNormalized String   @map("plate_normalized")
  renavamQuery    String?  @map("renavam_query")
  provider        String
  cost            Decimal  @db.Decimal(14, 4)
  success         Boolean
  errorCode       String?  @map("error_code")
  cachedResponse  Boolean  @default(false) @map("cached_response")
  snapshotJson    Json     @map("snapshot_json")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("senatran_lookup_audits")
}

/// Auditoria de consultas CNPJ cadastrais (snapshot completo; acesso administrativo).
model DocumentLookupAudit {
  id                 Int      @id @default(autoincrement())
  userId             Int      @map("user_id")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentNormalized String   @map("document_normalized")
  documentKind       String   @map("document_kind")
  provider           String
  cost               Decimal  @db.Decimal(14, 4)
  success            Boolean
  errorCode          String?  @map("error_code")
  cachedResponse     Boolean  @default(false) @map("cached_response")
  snapshotJson       Json     @map("snapshot_json")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("document_lookup_audits")
}

/// Lead CRM (single-tenant).
model StorefrontLead {
  id          Int       @id @default(autoincrement())
  name        String
  email       String
  phone       String
  message     String?
  vehicleId   Int?      @map("vehicle_id")
  vehicle     Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  source      String    @default("crm")
  consentText String    @map("consent_text")
  consentAt   DateTime  @map("consent_at")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([vehicleId])
  @@index([createdAt])
  @@index([readAt])
  @@map("storefront_leads")
}
